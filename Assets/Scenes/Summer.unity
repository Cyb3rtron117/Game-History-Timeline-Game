  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Another big turn-based rpg game was Wizardry: Proving Grounds of the Mad
    Overlord \u2013 or also referred to as Wizardry. In it, the player can create
    a party of up to 6 characters to aid them on their journey. The game offers 5
    different races, 3 alignments, 4 basic classes and 4 advanced classes \u2013
    inspired by Dungeons and Dragons 1st Edition. (Roddison, 2024). The goal is to
    explore, find treasure, level up by killing monsters, and then fighting the last
    boss at the bottom of the level to get a powerful amulet.\n\r\nThe game\u2019s
    party system and its spell-slot system was unique, and its implementation in
    Wizardry inspired many, including the team behind the later released Final Fantasy
    (Square, 1987) (Parish, 2017)\n\r\nSimilarly, it\u2019s random enemy encounters
    also later contributed to the creation of Dragon Quest (Enix, Spike Chunsoft,
    1986). (Kalata, 2008).\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 43a9a8ccb2969514899fad3ed6464bfc, type: 2}
  m_sharedMaterial: {fileID: 661757344227431810, guid: 43a9a8ccb2969514899fad3ed6464bfc, type: 2}
